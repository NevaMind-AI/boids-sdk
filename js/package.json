{
  "name": "@boids/sdk",
  "version": "0.1.0",
  "description": "JavaScript SDK and CLI for the Boids Responses API",
  "type": "module",
  "main": "./src/index.js",
  "types": "./src/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "default": "./src/index.js"
    }
  },
  "bin": {
    "boids": "./bin/boids.js"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "scripts": {
    "check": "node --check src/index.js && node --check bin/boids.js"
  },
  "keywords": [
    "boids",
    "sdk",
    "cli",
    "responses"
  ]
}
